# ---------------------------------------------------------------------------
# eyebench environment settings.
# ---------------------------------------------------------------------------

# Postgres
POSTGRES_USER=eyebench
POSTGRES_PASSWORD=eyebench
POSTGRES_DB=eyebench

# DB connection pool (per read service -> Postgres)
DB_POOL_MIN=2
DB_POOL_MAX=20

# Cache
CACHE_TTL=60

# Downstream HTTP behaviour (timeout/retry for service-to-service calls)
DOWNSTREAM_TIMEOUT=2.0
DOWNSTREAM_RETRIES=0

# Access-log sampling: log 1 in N successful (<400) requests; errors are always
# logged. 20 => ~5% of successful requests, keeping loop time off the hot path.
ACCESS_LOG_SAMPLE_N=20

# ---------------------------------------------------------------------------
# Load generator (open-loop, Zipfian, read-heavy)
# ---------------------------------------------------------------------------
# Target arrival rate in requests/sec.
RPS=300
# 0 = run indefinitely; otherwise run for this many seconds then stop.
DURATION_S=0
READ_FRACTION=0.9
ZIPF_S=1.1
NUM_PRODUCTS=1000
NUM_USERS=500
WARMUP_S=10


# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin
