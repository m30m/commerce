{
  "uid": "eyebench-profiling",
  "title": "Profiling — Continuous CPU (Pyroscope)",
  "tags": ["eyebench", "profiling"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "query": "gateway,product,cart,recommendation,worker",
        "current": { "text": "gateway", "value": "gateway" },
        "options": [
          { "text": "gateway", "value": "gateway", "selected": true },
          { "text": "product", "value": "product", "selected": false },
          { "text": "cart", "value": "cart", "selected": false },
          { "text": "recommendation", "value": "recommendation", "selected": false },
          { "text": "worker", "value": "worker", "selected": false }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "flamegraph",
      "title": "CPU flame graph — $service",
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
          "queryType": "profile",
          "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds",
          "labelSelector": "{service=\"$service\"}",
          "groupBy": []
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU usage over time — $service",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
          "queryType": "metrics",
          "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds",
          "labelSelector": "{service=\"$service\"}",
          "groupBy": []
        }
      ]
    }
  ]
}
