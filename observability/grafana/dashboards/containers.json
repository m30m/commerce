{
  "uid": "eyebench-containers",
  "title": "Containers — cAdvisor resource usage",
  "tags": ["eyebench", "generic"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU cores per container",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[1m]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory working set per container",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "container_memory_working_set_bytes{name!=\"\"}",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Network receive per container",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{name!=\"\"}[1m]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Network transmit per container",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name!=\"\"}[1m]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Filesystem usage per container",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (name) (container_fs_usage_bytes{name!=\"\"})",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU throttled periods per container (/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (name) (rate(container_cpu_cfs_throttled_periods_total{name!=\"\"}[1m]))",
          "legendFormat": "{{name}}"
        }
      ]
    }
  ]
}
