{
  "uid": "eyebench-use",
  "title": "USE — Utilisation / Saturation / Errors",
  "tags": ["eyebench", "generic"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Resident memory (RSS) by service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_resident_memory_bytes",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Event-loop lag by service (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "event_loop_lag_seconds",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "DB pool in-use vs size by service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "db_pool_in_use_connections",
          "legendFormat": "{{app}} in-use"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "db_pool_size",
          "legendFormat": "{{app}} size"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "DB pool acquire wait p99 by service (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (app, le) (rate(db_pool_wait_seconds_bucket[1m])))",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cache hit ratio (product)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (app) (rate(cache_requests_total{result=\"hit\"}[1m])) / sum by (app) (rate(cache_requests_total[1m]))",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "In-flight requests by service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "http_requests_in_progress",
          "legendFormat": "{{app}}"
        }
      ]
    }
  ]
}
