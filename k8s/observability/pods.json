{
  "uid": "eyebench-pods",
  "title": "Pods — resource usage & health (eyebench)",
  "tags": ["eyebench", "k8s"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU cores per pod",
      "description": "cAdvisor via kubelet. Summed per pod (minikube's cAdvisor omits the per-container label).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"eyebench\"}[1m]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory working set per pod",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"eyebench\"})",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Memory: working set vs limit",
      "description": "Working set (solid) against the pod's memory limit from kube-state-metrics (dashed). Pods approaching their limit are OOMKill candidates.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*limit.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 8], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"eyebench\"})",
          "legendFormat": "{{pod}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (pod) (kube_pod_container_resource_limits{namespace=\"eyebench\", resource=\"memory\"})",
          "legendFormat": "{{pod}} limit"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Container restarts per pod (cumulative)",
      "description": "kube-state-metrics. A rising line means a container is crash-looping (e.g. failed liveness probe).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (pod) (kube_pod_container_status_restarts_total{namespace=\"eyebench\"})",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Ready containers per pod",
      "description": "kube-state-metrics. Drops below the pod's container count indicate an unready (failing readiness) or restarting container.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (pod) (kube_pod_container_status_ready{namespace=\"eyebench\"})",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Node CPU utilisation (single-VM ceiling)",
      "description": "node-exporter. minikube is one VM — this is the hard cap all pods share, regardless of replica count.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m]))",
          "legendFormat": "node CPU busy"
        }
      ]
    }
  ]
}
