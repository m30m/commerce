{
  "uid": "eyebench-app",
  "title": "App — Single-service deep dive",
  "tags": ["eyebench", "app"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "app",
        "type": "query",
        "label": "App",
        "description": "Pick one service to zoom in on. Every panel below is scoped to it. The `app` (metrics) and `service` (logs) labels share the same value.",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, app)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "current": { "text": "gateway", "value": "gateway" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Serving — $app",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request & error rate (req/s)",
      "description": "Total inbound request rate for $app, with the 5xx error rate overlaid.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx errors" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum (rate(http_requests_total{app=\"$app\"}[1m]))",
          "legendFormat": "requests"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum (rate(http_requests_total{app=\"$app\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx errors"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Serving latency p50 / p95 / p99 (s)",
      "description": "histogram_quantile over http_request_duration_seconds for $app, across all endpoints.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"$app\"}[1m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"$app\"}[1m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"$app\"}[1m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Serving latency p99 by endpoint (s)",
      "description": "Which routes on $app are slow. One series per method + endpoint.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (method, endpoint, le) (rate(http_request_duration_seconds_bucket{app=\"$app\"}[1m])))",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Downstream calls — $app",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Downstream latency p99 by target (s)",
      "description": "histogram_quantile over downstream_request_duration_seconds — how long $app's outbound calls to each downstream service take. Empty for leaf services (e.g. product) that call nothing.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (target, le) (rate(downstream_request_duration_seconds_bucket{app=\"$app\"}[1m])))",
          "legendFormat": "{{target}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Downstream call rate by target & status",
      "description": "rate of downstream_requests_total from $app, split by target service and response status.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (target, status) (rate(downstream_requests_total{app=\"$app\"}[1m]))",
          "legendFormat": "{{target}} {{status}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Database — $app",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "DB query latency p99 by op (s)",
      "description": "histogram_quantile over db_query_duration_seconds for $app, per logical operation.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (op, le) (rate(db_query_duration_seconds_bucket{app=\"$app\"}[1m])))",
          "legendFormat": "{{op}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "DB query rate by op + pool acquire wait p99",
      "description": "Left: rate of db_queries_total per op. Overlaid: p99 pool-acquire wait for $app (right axis, seconds) — rising wait with flat query rate means pool saturation.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "qps", "min": 0 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pool wait p99" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.lineStyle", "value": { "dash": [8, 8], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (op) (rate(db_queries_total{app=\"$app\"}[1m]))",
          "legendFormat": "{{op}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(db_pool_wait_seconds_bucket{app=\"$app\"}[1m])))",
          "legendFormat": "pool wait p99"
        }
      ]
    },
    {
      "id": 11,
      "type": "row",
      "title": "Logs — $app",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "collapsed": false
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Log volume (lines/s) by level — stacked",
      "description": "Per-second log line rate for $app from Loki, one stacked series per level. Watch for a jump on warning/error.",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "warning" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (rate({job=\"docker\", service=\"$app\"}[$__interval]))",
          "legendFormat": "{{level}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 13,
      "type": "logs",
      "title": "Logs — $app",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 43 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\", service=\"$app\"} | json",
          "queryType": "range"
        }
      ]
    }
  ]
}
